#!/bin/sh

# Pre-commit hook: SECRET DETECTION
# Blocks commits containing common secret patterns

echo "🔍 Scanning for leaked secrets..."

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

for FILE in $STAGED_FILES; do
  # Skip binary files
  if [ -f "$FILE" ] && file "$FILE" | grep -q text; then
    if grep -E 'sk[-_](live_|test_)?[a-zA-Z0-9]{40,}|ghp_[a-zA-Z0-9]{36,}|github_pat_[a-zA-Z0-9_]{30,}|sbp_[a-f0-9]{40}|npm_[a-zA-Z0-9]{30,}|eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9\.[a-zA-Z0-9_-]+\.[a-zA-Z0-9_-]+|AKIA[0-9A-Z]{16}|AIza[0-9A-Za-z_-]{35}' "$FILE" > /dev/null 2>&1; then
      echo "❌ BLOCKED: Potential secret detected in $FILE"
      echo "  Patterns: sk_live_, ghp_, github_pat_, sbp_, npm_, JWT, AKIA, AIza"
      echo "  Remove the secret before committing."
      exit 1
    fi
  fi
done

echo "✅ No secrets found."
